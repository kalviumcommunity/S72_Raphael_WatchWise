# Database Configuration
MONGO_URI=mongodb://admin:password123@localhost:27017/watchwise?authSource=admin

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server Configuration
NODE_ENV=development
PORT=3000

# CORS Configuration
FRONTEND_URL=http://localhost:5173
PRODUCTION_FRONTEND_URL=https://watchwisely.netlify.app

# File Upload Configuration
UPLOAD_PATH=./uploads/profile-images
MAX_FILE_SIZE=5242880

# TMDB API Key (server-side only — never expose to the client)
# Get yours at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your-tmdb-api-key-here

# PostgreSQL / pgvector — vector similarity search
# Install pgvector: https://github.com/pgvector/pgvector
# Leave PG_PASSWORD unset to disable vector search (falls back to TMDB/Jikan)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=watchwise
PG_USER=postgres
PG_PASSWORD=your-postgres-password
PG_SSL=false
